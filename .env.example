OPENCODE_API_KEY=sk-...
LOCAL_API_KEY=my-secret-key
PORT=3000
DEFAULT_MODEL=big-pickle
ALLOWED_MODELS=big-pickle,minimax-m2.5-free,gpt-5-nano

# Mode: 'api' (default, proxy to opencode.ai) or 'opencode' (local opencode serve)
MODE=api
# Port for opencode serve (only used when MODE=opencode)
# OPENCODE_PORT=54321
